# Telnyx
TELNYX_API_KEY=
TELNYX_FAX_CONNECTION_ID=
TELNYX_FAX_FROM_NUMBER=
# Keep for backward compatibility (if you still use shared secret based hooks)
TELNYX_FAX_WEBHOOK_SECRET=
