APP2_INGEST_SHARED_SECRET=replace-with-shared-secret

# App1
APP1_KOBIL_CLIENT_ID=
APP1_KOBIL_CLIENT_SECRET=
APP1_BASE_URL=http://localhost:3001

# App2
APP2_KOBIL_CLIENT_ID=
APP2_KOBIL_CLIENT_SECRET=
